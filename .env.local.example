# Supabase (Project Settings > API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service role key — server-only, never exposed to the browser, bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Twilio Verify (same account/service as daily-tracker)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Locally, OTP automatically falls back to a fixed on-screen code (123456)
# whenever Twilio isn't configured — no flag needed for that. This flag is
# ONLY for a deployed (production) environment that doesn't have Twilio set
# up yet, e.g. a temporary/staging domain. Leave unset normally — setting
# this to "true" on a real production deployment without Twilio would let
# anyone log in as anyone using code 123456. It becomes a no-op automatically
# once TWILIO_* above are filled in for real.
ALLOW_DUMMY_OTP=

# Session signing secrets — generate two long random strings, keep them secret
# e.g. node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
ADMIN_SESSION_SECRET=

# Comma-separated E.164 phone numbers allowed to sign in at /admin/login
ADMIN_PHONES=+910000000000

# Google Cloud OAuth Client ID (Web application) — used client-side only for the
# optional "back up to your own Google Drive" feature. See README for setup.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3000
